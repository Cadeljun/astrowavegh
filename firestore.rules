
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check for admin role
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Public read collections
    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /talent/{talentId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /gallery/{photoId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Public create-only forms
    match /contacts/{id} {
      allow create: if true;
      allow read, write: if isAdmin();
    }
    match /waitlist/{id} {
      allow create: if true;
      allow read, write: if isAdmin();
    }
    match /talent_inquiries/{id} {
      allow create: if true;
      allow read, write: if isAdmin();
    }

    // CMS Content - Public Read, Admin Write
    match /cms_content/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /cms_sections/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /cms_seo/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /cms_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // All other documents are admin-only
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
