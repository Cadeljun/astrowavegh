
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── HELPER FUNCTIONS ───────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Identify the specific developer account
    function isDevEmail() {
      return isSignedIn() && request.auth.token.email == 'junioraquils143@gmail.com';
    }

    function userExists() {
      return exists(/databases/$(database)/documents/user_roles/$(request.auth.uid));
    }

    function getUserRole() {
      return isDevEmail() ? 'SUPER_ADMIN' : (userExists() ? get(/databases/$(database)/documents/user_roles/$(request.auth.uid)).data.role : 'VIEWER');
    }

    function isActive() {
      return isDevEmail() || (userExists() && get(/databases/$(database)/documents/user_roles/$(request.auth.uid)).data.active == true);
    }

    function isSuperAdmin() {
      return isSignedIn() 
        && isActive()
        && getUserRole() == 'SUPER_ADMIN';
    }

    function isEditor() {
      return isSignedIn()
        && isActive()
        && (
          getUserRole() == 'SUPER_ADMIN' ||
          getUserRole() == 'EDITOR'
        );
    }

    function canWrite() {
      return isSignedIn()
        && isActive()
        && getUserRole() != 'VIEWER';
    }

    function isDeveloper() {
      return isSignedIn()
        && isActive()
        && (
          getUserRole() == 'SUPER_ADMIN' ||
          getUserRole() == 'DEVELOPER'
        );
    }

    // ─── USER ROLES ─────────────────
    match /user_roles/{uid} {
      allow read: if isSignedIn() 
        && (request.auth.uid == uid 
            || isSuperAdmin());
      allow write: if isSuperAdmin();
    }

    // ─── USERS ──────────────────────
    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isOwner(uid) || isSuperAdmin();
    }

    // ─── EVENTS ─────────────────────
    match /events/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // ─── TALENT ─────────────────────
    match /talent/{id} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /talent_profiles/{uid} {
      allow read: if true;
      allow write: if isOwner(uid) || isSuperAdmin();
    }

    // ─── BOOKINGS ───────────────────
    match /bookings/{id} {
      allow read: if isSignedIn() && (
        resource.data.organizerId == request.auth.uid ||
        resource.data.talentId == request.auth.uid ||
        isSuperAdmin()
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.organizerId == request.auth.uid ||
        resource.data.talentId == request.auth.uid ||
        isSuperAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // ─── GALLERY ────────────────────
    match /gallery/{id} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // ─── UPLOADS ────────────────────
    match /uploads/{id} {
      allow read: if isSignedIn();
      allow write: if canWrite() 
        && getUserRole() != 'EDITOR';
    }

    // ─── CMS (Editor + above) ───────
    match /cms_content/{id} {
      allow read: if true;
      allow write: if isEditor();
    }

    match /cms_settings/{id} {
      allow read: if true;
      allow write: if isEditor();
    }

    match /cms_sections/{id} {
      allow read: if true;
      allow write: if isEditor();
    }

    match /cms_seo/{id} {
      allow read: if true;
      allow write: if isEditor();
    }

    // ─── CONTACTS ───────────────────
    match /contacts/{id} {
      allow create: if true;
      allow read: if isSignedIn();
      allow update, delete: if canWrite()
        && getUserRole() != 'EDITOR';
    }

    // ─── WAITLIST ───────────────────
    match /waitlist/{id} {
      allow create: if true;
      allow read: if isSignedIn();
      allow update, delete: if isSuperAdmin();
    }

    // ─── TALENT INQUIRIES ───────────
    match /talent_inquiries/{id} {
      allow create: if true;
      allow read: if isSignedIn();
      allow update, delete: if canWrite()
        && getUserRole() != 'EDITOR';
    }
  }
}
