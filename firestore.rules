
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public read collections
    match /events/{eventId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /talent/{talentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /gallery/{photoId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Public create only
    match /contacts/{id} {
      allow create: if true;
      allow read, write: if request.auth != null;
    }
    match /waitlist/{id} {
      allow create: if true;
      allow read, write: if request.auth != null;
    }
    match /talent_inquiries/{id} {
      allow create: if true;
      allow read, write: if request.auth != null;
    }

    // CMS - Public Read, Admin Write
    match /cms_content/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /cms_sections/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /cms_seo/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /cms_settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Default catch-all
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
