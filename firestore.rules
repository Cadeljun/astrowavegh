rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── HELPER FUNCTIONS ───────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isSuperAdmin() {
      return isSignedIn() && 
        (request.auth.token.email == 'junioraquils143@gmail.com' || 
         exists(/databases/$(database)/documents/user_roles/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/user_roles/$(request.auth.uid)).data.role == 'SUPER_ADMIN');
    }

    // ─── USERS & ROLES ──────────────
    match /user_roles/{uid} {
      allow read: if isOwner(uid) || isSuperAdmin();
      allow write: if isSuperAdmin();
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isOwner(uid) || isSuperAdmin();
    }

    // ─── PROFILES ───────────────────
    match /organizer_profiles/{uid} {
      allow read: if isSignedIn();
      allow write: if isOwner(uid) || isSuperAdmin();
    }

    match /talent_profiles/{uid} {
      allow read: if true;
      allow write: if isOwner(uid) || isSuperAdmin();
    }

    // ─── EVENTS ─────────────────────
    match /events/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSuperAdmin() || (isSignedIn() && resource.data.organizerId == request.auth.uid);
      allow delete: if isSuperAdmin();
    }

    // ─── BOOKINGS ───────────────────
    match /bookings/{id} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.organizerId || 
        request.auth.uid == resource.data.talentId || 
        isSuperAdmin()
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.organizerId || 
        request.auth.uid == resource.data.talentId || 
        isSuperAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // ─── RATINGS ────────────────────
    match /ratings/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSuperAdmin();
    }

    // ─── MATCHES ────────────────────
    match /matches/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // ─── NOTIFICATIONS ──────────────
    match /notifications/{id} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.userId || isSuperAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }

    // ─── MARKETING COLLECTIONS ──────
    match /contacts/{id} {
      allow create: if true;
      allow read: if isSuperAdmin();
    }

    match /waitlist/{id} {
      allow create: if true;
      allow read: if isSuperAdmin();
    }

    match /gallery/{id} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /uploads/{id} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /cms_content/{id} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /cms_settings/{id} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
  }
}