{
  "entities": {
    "User": {
      "title": "User",
      "description": "Core identity and profile state for AstroWave participants.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["organizer", "talent", "both", null] },
        "onboarded": { "type": "boolean" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "TalentProfile": {
      "title": "Talent Profile",
      "description": "Professional metrics and visibility state for creative talent.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "stageName": { "type": "string" },
        "category": { "type": "string", "enum": ["DJ", "MC", "Hypeman", "Singer", "Dancer", "Comedian", "Band", "Other"] },
        "bio": { "type": "string" },
        "city": { "type": "string" },
        "waveScore": { "type": "number" },
        "averageRating": { "type": "number" },
        "eventCount": { "type": "number" },
        "available": { "type": "boolean" },
        "verified": { "type": "boolean" }
      }
    },
    "PlatformEvent": {
      "title": "Platform Event",
      "description": "An active event brief seeking talent matching.",
      "type": "object",
      "properties": {
        "organizerId": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "venue": { "type": "string" },
        "city": { "type": "string" },
        "talentCategory": { "type": "string" },
        "talentBudget": { "type": "number" },
        "status": { "type": "string", "enum": ["open", "matched", "booked", "completed", "cancelled"] }
      }
    },
    "Booking": {
      "title": "Booking",
      "description": "A confirmed professional engagement record.",
      "type": "object",
      "properties": {
        "eventId": { "type": "string" },
        "talentId": { "type": "string" },
        "organizerId": { "type": "string" },
        "agreedPrice": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "accepted", "declined", "completed", "cancelled"] }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{uid}": { "schema": "#/entities/User", "description": "Global user accounts." },
    "/talent_profiles/{uid}": { "schema": "#/entities/TalentProfile", "description": "Professional talent data." },
    "/platform_events/{id}": { "schema": "#/entities/PlatformEvent", "description": "Active event briefs." },
    "/bookings/{id}": { "schema": "#/entities/Booking", "description": "Transaction records." },
    "/matches/{eventId}": { "schema": { "type": "object" }, "description": "Cached algorithmic match results." },
    "/cms_settings/global": { "schema": { "type": "object" }, "description": "Global brand assets and system configuration." }
  }
}