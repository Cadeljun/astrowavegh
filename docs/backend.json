
{
  "entities": {
    "Event": {
      "title": "Event",
      "description": "AstroWave events, parties, and concerts.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "venue": { "type": "string" },
        "category": { "type": "string", "enum": ["Parties", "Concerts", "Networking", "Nightlife", "Festivals"] },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "ticketLink": { "type": "string" },
        "organizerId": { "type": "string" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "date", "venue", "category", "active"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Base user data for the AstroWave platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["ORGANIZER", "TALENT", "ADMIN", "PENDING"] },
        "onboarded": { "type": "boolean" },
        "profileImageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "OrganizerProfile": {
      "title": "Organizer Profile",
      "description": "Extended metadata for event organizers.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "companyName": { "type": "string" },
        "bio": { "type": "string" },
        "website": { "type": "string" },
        "location": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Talent": {
      "title": "Talent",
      "description": "DJs and artists managed by or registered on AstroWave.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "stageName": { "type": "string" },
        "role": { "type": "string" },
        "bio": { "type": "string" },
        "imageUrl": { "type": "string" },
        "instagram": { "type": "string" },
        "soundcloud": { "type": "string" },
        "spotify": { "type": "string" },
        "waveScore": { "type": "number" },
        "averageRating": { "type": "number" },
        "eventCount": { "type": "number" },
        "ratingCount": { "type": "number" },
        "recencyFactor": { "type": "number" },
        "lastEventDate": { "type": "string", "format": "date-time" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "role", "active"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A talent booking record.",
      "type": "object",
      "properties": {
        "eventId": { "type": "string" },
        "eventName": { "type": "string" },
        "eventDate": { "type": "string" },
        "talentId": { "type": "string" },
        "talentName": { "type": "string" },
        "organizerId": { "type": "string" },
        "organizerName": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "CONFIRMED", "CANCELLED", "COMPLETED"] },
        "price": { "type": "number" },
        "rating": { "type": "number" },
        "review": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "reviewedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["eventId", "talentId", "organizerId", "status"]
    },
    "Rating": {
      "title": "Rating",
      "description": "Post-event talent review.",
      "type": "object",
      "properties": {
        "bookingId": { "type": "string" },
        "talentId": { "type": "string" },
        "organizerId": { "type": "string" },
        "score": { "type": "number", "minimum": 1, "maximum": 5 },
        "comment": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Match": {
      "title": "Match",
      "description": "Cached AI matching result.",
      "type": "object",
      "properties": {
        "eventId": { "type": "string" },
        "talentId": { "type": "string" },
        "matchPercentage": { "type": "number" },
        "reasoning": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Notification": {
      "title": "Notification",
      "description": "In-app user notification.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "link": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "#/entities/UserProfile",
      "description": "Unified platform user profiles."
    },
    "/organizer_profiles/{uid}": {
      "schema": "#/entities/OrganizerProfile",
      "description": "Specific metadata for organizers."
    },
    "/talent_profiles/{uid}": {
      "schema": "#/entities/Talent",
      "description": "Extended profiles for talent users."
    },
    "/events/{eventId}": {
      "schema": "#/entities/Event",
      "description": "Collection of public events and experiences."
    },
    "/bookings/{bookingId}": {
      "schema": "#/entities/Booking",
      "description": "Transaction log for bookings."
    },
    "/ratings/{ratingId}": {
      "schema": "#/entities/Rating",
      "description": "Collection of post-event ratings."
    },
    "/matches/{matchId}": {
      "schema": "#/entities/Match",
      "description": "Cached AI-generated matches."
    },
    "/notifications/{notificationId}": {
      "schema": "#/entities/Notification",
      "description": "User notification stream."
    }
  }
}
