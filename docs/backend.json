
{
  "entities": {
    "Event": {
      "title": "Event",
      "description": "AstroWave events, parties, and concerts.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "venue": { "type": "string" },
        "category": { "type": "string", "enum": ["Parties", "Concerts", "Networking", "Nightlife", "Festivals"] },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "ticketLink": { "type": "string" },
        "organizerId": { "type": "string" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "date", "venue", "category", "active"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Base user data for the AstroWave platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["ORGANIZER", "TALENT", "ADMIN"] },
        "onboarded": { "type": "boolean" },
        "profileImageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Talent": {
      "title": "Talent",
      "description": "DJs and artists managed by or registered on AstroWave.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "stageName": { "type": "string" },
        "role": { "type": "string" },
        "bio": { "type": "string" },
        "imageUrl": { "type": "string" },
        "instagram": { "type": "string" },
        "soundcloud": { "type": "string" },
        "spotify": { "type": "string" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "role", "active"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A talent booking record.",
      "type": "object",
      "properties": {
        "eventId": { "type": "string" },
        "eventName": { "type": "string" },
        "eventDate": { "type": "string" },
        "talentId": { "type": "string" },
        "talentName": { "type": "string" },
        "organizerId": { "type": "string" },
        "organizerName": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "CONFIRMED", "CANCELLED", "COMPLETED"] },
        "price": { "type": "number" },
        "rating": { "type": "number", "minimum": 1, "maximum": 5 },
        "review": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["eventId", "talentId", "organizerId", "status"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "#/entities/UserProfile",
      "description": "Unified platform user profiles."
    },
    "/events/{eventId}": {
      "schema": "#/entities/Event",
      "description": "Collection of public events and experiences."
    },
    "/talent_profiles/{uid}": {
      "schema": "#/entities/Talent",
      "description": "Extended profiles for talent users."
    },
    "/bookings/{bookingId}": {
      "schema": "#/entities/Booking",
      "description": "Transaction log for bookings."
    }
  }
}
